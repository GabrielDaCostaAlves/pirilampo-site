rules_version = '2';

// Regras do Cloud Firestore para a Escola Pirilampo.
// Leitura pública (site institucional) e escrita apenas para usuários
// autenticados (equipe da escola, via Firebase Authentication).
service cloud.firestore {
  match /databases/{database}/documents {

    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

rules_version = '2';

// Regras do Firebase Storage para a Escola Pirilampo.
// Imagens são públicas para leitura; envio/remoção apenas para a equipe
// autenticada. Limita a 5 MB e somente arquivos de imagem.
service firebase.storage {
  match /b/{bucket}/o {
    match /{folder}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
